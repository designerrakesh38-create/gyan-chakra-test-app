{
  "name": "gyan-chakra-preview",
  "version": "1.0.0",
  "private": true,
  "description": "Gyan Chakra local preview and Android wrapper",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "start:lan": "HOST=0.0.0.0 node server.js",
    "set:api": "node scripts/set-api-url.mjs",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "android:apk": "cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3"
  },
  "devDependencies": {}
}
